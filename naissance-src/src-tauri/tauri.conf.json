{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Niam-Bay",
  "version": "0.1.0",
  "identifier": "com.niambay.jarvis",
  "build": {
    "frontendDist": "../dist/niam-bay-jarvis/browser",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "npm run start",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "circle",
        "title": "Niam-Bay",
        "width": 120,
        "height": 120,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "x": 50,
        "y": 50
      },
      {
        "label": "panel",
        "title": "Niam-Bay Panel",
        "url": "/panel",
        "width": 420,
        "height": 680,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "x": 50,
        "y": 180
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
